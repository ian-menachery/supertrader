<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ run_id }} — supertrader tear sheet</title>
<style>
  body { font-family: -apple-system, "Segoe UI", system-ui, sans-serif; max-width: 1100px; margin: 2rem auto; padding: 0 1rem; color: #222; }
  h1 { font-size: 1.5rem; margin: 0 0 0.5rem 0; }
  h2 { font-size: 1.1rem; margin: 1.5rem 0 0.4rem 0; border-bottom: 1px solid #ccc; padding-bottom: 0.2rem; }
  .meta { font-size: 0.85rem; color: #555; }
  .meta dl { display: grid; grid-template-columns: max-content 1fr; gap: 0.15rem 0.8rem; margin: 0.5rem 0; }
  .meta dt { font-weight: 600; }
  .warning { background: #fff7e5; border-left: 4px solid #d49500; padding: 0.6rem 0.8rem; font-family: ui-monospace, "SF Mono", Consolas, monospace; font-size: 0.85rem; white-space: pre-wrap; }
  table { border-collapse: collapse; margin: 0.4rem 0; font-size: 0.9rem; }
  th, td { border: 1px solid #ddd; padding: 0.25rem 0.6rem; text-align: right; }
  th { background: #f5f5f5; text-align: center; }
  td:first-child, th:first-child { text-align: left; }
  img { display: block; max-width: 100%; margin: 0.4rem 0; }
  footer { margin-top: 2rem; font-size: 0.75rem; color: #888; border-top: 1px solid #eee; padding-top: 0.5rem; }
</style>
</head>
<body>
<h1>{{ run_id }}</h1>
<div class="meta">
  <dl>
    <dt>config_hash</dt><dd>{{ config_hash_short }}</dd>
    <dt>git_sha</dt><dd>{{ git_sha_short }}{% if git_dirty %} <strong>(DIRTY)</strong>{% endif %}</dd>
    <dt>python</dt><dd>{{ python_version }}</dd>
    <dt>supertrader</dt><dd>{{ supertrader_version }}</dd>
    <dt>started_at</dt><dd>{{ started_at }}</dd>
    <dt>ended_at</dt><dd>{{ ended_at or "—" }}</dd>
    <dt>status</dt><dd>{{ status }}</dd>
  </dl>
</div>

<h2>Universe caveats</h2>
<pre class="warning">{{ universe_warning }}</pre>

<h2>Metrics</h2>
<table>
  <thead>
    <tr>
      <th>Metric</th>
      <th>TRAIN</th>
      <th>TEST</th>
      <th>HOLDOUT</th>
    </tr>
  </thead>
  <tbody>
    {% for row in metrics_rows %}
    <tr>
      <td>{{ row.label }}</td>
      <td>{{ row.train }}</td>
      <td>{{ row.test }}</td>
      <td>{{ row.holdout }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<h2>Equity curve</h2>
<img alt="Equity curve" src="data:image/png;base64,{{ equity_png_b64 }}">

<h2>Drawdown</h2>
<img alt="Drawdown" src="data:image/png;base64,{{ drawdown_png_b64 }}">

<h2>Exposure (gross + net)</h2>
<img alt="Exposure" src="data:image/png;base64,{{ exposure_png_b64 }}">

<h2>Monthly returns</h2>
<table>
  <thead>
    <tr>
      <th>Month</th>
      <th>Return</th>
    </tr>
  </thead>
  <tbody>
    {% for row in monthly_returns %}
    <tr>
      <td>{{ row.month }}</td>
      <td>{{ row.value }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<footer>
  Generated {{ generated_at }} by supertrader {{ supertrader_version }}.
</footer>
</body>
</html>
